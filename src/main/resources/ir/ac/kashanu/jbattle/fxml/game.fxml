<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!-- Battle screen layout. The arena's sprites, clip and render loop are wired in
     GameController; here we only declare the static chrome. -->
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ir.ac.kashanu.jbattle.ui.GameController"
            stylesheets="@../style/game.css">
    <top>
        <!-- identity, health, controls -->
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="top-bar">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Label fx:id="heroLabel" styleClass="hero-name"/>
            <Label text="❤" styleClass="heart"/>
            <ProgressBar fx:id="healthBar" prefWidth="220" progress="1.0"/>
            <Label fx:id="healthLabel" styleClass="health-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="newPlayButton" text="New Play" onAction="#onNewPlay"/>
            <Button text="Logout" onAction="#onLogout"/>
        </HBox>
    </top>
    <center>
        <!-- arena grows to fill the center; sprites are added at runtime -->
        <Pane fx:id="arena" styleClass="arena" minWidth="400" minHeight="300"/>
    </center>
    <right>
        <!-- story board -->
        <VBox spacing="6" styleClass="board">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Label text="📜 Battle Chronicle" styleClass="board-title"/>
            <TextArea fx:id="storyBoard" editable="false" wrapText="true"
                      prefWidth="340" minWidth="280" VBox.vgrow="ALWAYS"/>
        </VBox>
    </right>
</BorderPane>
